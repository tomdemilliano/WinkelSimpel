rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Centrale productbibliotheek
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.role == 'app_admin';
    }

    // Centrale categoriebibliotheek
    match /categories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.role == 'app_admin';
    }

    // Product submissions
    match /productSubmissions/{submissionId} {
      allow create: if request.auth != null
                    && request.auth.token.role in ['guide', 'org_admin'];
      allow read, update: if request.auth.token.role == 'app_admin';
    }

    // Centrale winkelbibliotheek
    match /stores/{storeId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.role == 'app_admin';
    }

    // Winkel submissions
    match /storeSubmissions/{submissionId} {
      allow create: if request.auth != null
                    && request.auth.token.role in ['guide', 'org_admin'];
      allow read, update: if request.auth.token.role == 'app_admin';
    }

    // Toegangsverzoeken (stand-alone gebruikers die toegang aanvragen bij een org)
    // Schrijven gaat via Admin SDK API-routes — geen client-write nodig
    match /accessRequests/{requestId} {
      allow read: if request.auth != null && (
        resource.data.requestingUserId == request.auth.uid
        || (request.auth.token.role == 'org_admin'
            && request.auth.token.orgId == resource.data.targetOrgId)
        || request.auth.token.role == 'app_admin'
      );
    }

    // Organisaties
    match /organizations/{orgId} {
      allow read, write: if request.auth.token.role == 'app_admin';

      // Ingelogde gebruikers kunnen niet-privé organisaties lezen
      // (voor de zoekfunctie bij toegang aanvragen)
      allow read: if request.auth != null && resource.data.isPrivate != true;

      // Begeleiders mogen enkel de steminstelling (defaultVoiceName) aanpassen
      allow update: if request.auth.token.orgId == orgId
                    && request.auth.token.role in ['guide', 'org_admin']
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['defaultVoiceName']);

      match /members/{memberId} {
        allow read, write: if request.auth.token.role == 'app_admin'
                           || (request.auth.token.orgId == orgId
                               && request.auth.token.role in ['guide', 'org_admin']);
      }

      match /groups/{groupId} {
        allow read, write: if request.auth.token.role == 'app_admin'
                           || (request.auth.token.orgId == orgId
                               && request.auth.token.role in ['guide', 'org_admin']);
      }

      match /products/{productId} {
        allow read, write: if request.auth.token.role == 'app_admin'
                           || (request.auth.token.orgId == orgId
                               && request.auth.token.role in ['guide', 'org_admin']);
      }

      match /stores/{storeId} {
        allow read, write: if request.auth.token.role == 'app_admin'
                           || (request.auth.token.orgId == orgId
                               && request.auth.token.role in ['guide', 'org_admin']);
      }

      match /categories/{categoryId} {
        allow read, write: if request.auth.token.role == 'app_admin'
                           || (request.auth.token.orgId == orgId
                               && request.auth.token.role in ['guide', 'org_admin']);
      }

      match /tags/{tagId} {
        allow read, write: if request.auth.token.role == 'app_admin'
                           || (request.auth.token.orgId == orgId
                               && request.auth.token.role in ['guide', 'org_admin']);
      }

      match /shoppingLists/{listId} {
        allow read, write: if request.auth.token.role == 'app_admin'
                           || (request.auth.token.orgId == orgId
                               && request.auth.token.role in ['guide', 'org_admin']);

        match /items/{itemId} {
          allow read, write: if request.auth.token.role == 'app_admin'
                             || (request.auth.token.orgId == orgId
                                 && request.auth.token.role in ['guide', 'org_admin']);
        }
      }
    }
  }
}
